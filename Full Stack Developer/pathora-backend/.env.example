# ══════════════════════════════════════════════════════════════════════════════
# Path`Ora Backend — Environment Variables
# Salin file ini ke .env dan isi nilainya sebelum menjalankan server.
# JANGAN commit file .env ke version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
PORT=
NODE_ENV=         # development | production | test

# ── Database (SDD §3.1, §9.1) ─────────────────────────────────────────────────
# Connection string lengkap — pg.Pool menerima ini secara langsung.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=

# ── JWT (SEC-002) ─────────────────────────────────────────────────────────────
# Minimal 32 karakter. Generate dengan:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_random_secret_of_at_least_32_characters
JWT_EXPIRES_IN=

# ── AI Gateway (FR-013, FR-015, BTS-03) ───────────────────────────────────────
# Set USE_MOCK_AI=true untuk development tanpa layanan AI nyata
USE_MOCK_AI=

# URL layanan AI — wajib diisi bila USE_MOCK_AI=false
# AI_BASE_URL=http://localhost:8000

# Timeout request ke AI dalam milidetik (NFR-003)
AI_TIMEOUT_MS=30000

# ── CORS (SEC-007) ────────────────────────────────────────────────────────────
# Comma-separated list origin yang diizinkan
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# ── Upload (VAL-004) ──────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=5

# ── Rate Limiting (SEC-008, NFR-008) ──────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 menit
RATE_LIMIT_MAX=100            # endpoint umum
STRICT_RATE_LIMIT_MAX=10      # login, register, analyze

# ── Logging (NFR-022) ─────────────────────────────────────────────────────────
# Level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
